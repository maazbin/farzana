# =============================================================================
# Farzana — single-user personal memory aide
#   cp .env.example .env
# =============================================================================

# --- Telegram (required) -----------------------------------------------------
# @BotFather → /newbot → token
TELEGRAM_BOT_TOKEN=
# Your numeric id only (@userinfobot) — this bot is for ONE person
TELEGRAM_USER_ID=
# Random path secret for webhook URL
TELEGRAM_WEBHOOK_SECRET=change-me-to-a-long-random-string

# --- OpenAI ------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
OPENAI_STT_MODEL=whisper-1

# --- Redis / Celery (eager=true = no Redis needed) ---------------------------
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_TASK_ALWAYS_EAGER=true

# Voice + proactive
VOICE_REPLIES=true
VOICE_REPLIES_ALWAYS=false
PROACTIVE_ENABLED=true
PROACTIVE_MAX_PER_DAY=3
MORNING_BRIEF_HOUR_UTC=7
EVENING_DEBRIEF_HOUR_UTC=19
PROACTIVE_SCAN_MINUTES=60

# --- App ---------------------------------------------------------------------
APP_ENV=local
# Public HTTPS origin that reaches this app (no path). e.g. ngrok or your domain
PUBLIC_BASE_URL=
VAULT_PATH=./vault
LOG_LEVEL=INFO
USER_DISPLAY_NAME=there

# If api.telegram.org is blocked on the host machine:
# HTTPS_PROXY=http://127.0.0.1:7890
