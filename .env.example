# =============================================================================
# Farzana — copy this file to ".env" and fill in values
#   PowerShell:  Copy-Item .env.example .env
# =============================================================================

# --- Telegram (required) -----------------------------------------------------
# 1) Open Telegram → search @BotFather → /newbot → copy the token
# 2) Message your new bot once (press Start)
# 3) Get your numeric user id: search @userinfobot → /start → copy Id
TELEGRAM_BOT_TOKEN=
# true = any Telegram user can talk to Farzana
TELEGRAM_ALLOW_ALL_USERS=true
# optional allowlist if TELEGRAM_ALLOW_ALL_USERS=false
TELEGRAM_ALLOWLIST_USER_IDS=
# Random string you invent (used in webhook URL path)
TELEGRAM_WEBHOOK_SECRET=change-me-to-a-long-random-string

# --- OpenAI (required for real replies; optional for /health only) -----------
# https://platform.openai.com/api-keys  → Create new secret key
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
OPENAI_STT_MODEL=whisper-1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Redis / Celery (required for worker path) -------------------------------
# Local default after installing Redis (or: docker run -d -p 6379:6379 redis:7)
REDIS_URL=redis://127.0.0.1:6379/0
# true = run tasks inside the API process (no Redis/worker needed for first smoke test)
CELERY_TASK_ALWAYS_EAGER=true

# Voice + proactive
VOICE_REPLIES=true
VOICE_REPLIES_ALWAYS=false
PROACTIVE_ENABLED=true
PROACTIVE_MAX_PER_DAY=3
MORNING_BRIEF_HOUR_UTC=7
EVENING_DEBRIEF_HOUR_UTC=19
PROACTIVE_SCAN_MINUTES=60

# --- App ---------------------------------------------------------------------
APP_ENV=local
# Public HTTPS origin that reaches this app (no path, no trailing slash).
# Local dev (optional): ngrok → https://xxxx.ngrok-free.app
# Server: your own domain → https://farzana.example.com
# The app does not hardcode any host; you choose.
PUBLIC_BASE_URL=
VAULT_PATH=./vault
LOG_LEVEL=INFO
USER_DISPLAY_NAME=there

# If api.telegram.org times out, use VPN or:
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890


