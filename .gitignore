# --- Secrets & local env (NEVER commit) ---
.env
.env.*
!.env.example
deploy/server.env
deploy/infra.env
deploy/keys/
deploy/*.pem
deploy/farzana-dev.pem
deploy/farzana-app.tgz
**/*.pem
**/id_rsa
**/id_ed25519

# Terraform local / state (if using local backend)
